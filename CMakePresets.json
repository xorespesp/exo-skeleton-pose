{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/dependency/vcpkg_installed",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "win64-base-rel",
      "hidden": true,
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win64-base-dbg",
      "hidden": true,
      "inherits": "windows-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "win64-rel",
      "displayName": "W64-REL",
      "inherits": "win64-base-rel"
    },
    {
      "name": "win64-dbg",
      "displayName": "W64-DBG",
      "inherits": "win64-base-dbg"
    },

    {
      "name": "win64-rel-test",
      "displayName": "W64-REL (Test)",
      "inherits": "win64-base-rel"
    },
    {
      "name": "win64-dbg-test",
      "displayName": "W64-DBG (Test)",
      "inherits": "win64-base-dbg"
    }
  ],
  "buildPresets": [
    {
      "name": "win64-rel",
      "configurePreset": "win64-rel"
    },
    {
      "name": "win64-dbg",
      "configurePreset": "win64-dbg"
    },
    {
      "name": "win64-rel-test",
      "configurePreset": "win64-rel-test"
    },
    {
      "name": "win64-dbg-test",
      "configurePreset": "win64-dbg-test"
    }
  ]
}